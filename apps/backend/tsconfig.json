{
  "extends": "@repo/typescript-config/tsconfig.node",
  "include": ["src"],
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "~/*": ["./src/*"]
    },
    "outDir": "./dist",
    "noEmit": false,
    "types": ["node"],
    "sourceMap": true
  }
}
